{
  "expo": {
    "name": "Fashion Retail Platform",
    "slug": "fashion-retail-cameroon",
    "version": "1.0.0",
    "orientation": "default",
    "userInterfaceStyle": "light",
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#F8F5EE"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.fashionretail.cameroon"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#F8F5EE"
      },
      "package": "com.fashionretail.cameroon"
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png",
      "name": "Fashion Retail Platform - Manage Your Fashion Business",
      "description": "Complete platform for fashion retailers in Cameroon. Manage inventory, orders, customers, and WhatsApp communication all in one place.",
      "backgroundColor": "#F8F5EE",
      "themeColor": "#2ECC71"
    },
    "plugins": [
      "expo-router"
    ],
    "scheme": "fashion-retail",
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "fashion-retail-cameroon"
      }
    },
    "experiments": {
      "typedRoutes": true
    }
  }
}
